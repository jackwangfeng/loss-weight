# Gemini API 配置
# 请在这里配置你的 Gemini API Key

# Gemini API Key (必需) - 请替换为你的真实 API Key
gemini_api_key: "YOUR_GEMINI_API_KEY_HERE"

# Gemini API URL (可选，默认使用官方地址)
gemini_api_url: "https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent"

# Vision API 配置 (用于食物识别，可选 - 如果为空则使用 gemini_api_key)
vision_api_key: ""
vision_api_url: "https://generativelanguage.googleapis.com/v1beta/models/gemini-pro-vision:generateContent"

# 其他配置
project_name: "Loss Weight AI"
version: "1.0.0"
api_prefix: "/v1"
port: 8000
debug: true

# 数据库配置
database_url: "sqlite:///tmp/loss_weight.db"

# JWT 配置
secret_key: "your-secret-key-change-in-production"
jwt_expire_days: 7
